    "eslint-plugin-import": "^2.32.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.7"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
